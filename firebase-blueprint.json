{
  "entities": {
    "Medication": {
      "title": "Medication",
      "description": "A medication item in the pharmacy inventory.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the medication." },
        "category": { "type": "string", "description": "The therapeutic category." },
        "stock": { "type": "number", "description": "Current quantity in stock." },
        "reorderThreshold": { "type": "number", "description": "Stock level that triggers a reorder alert." },
        "expirationDate": { "type": "string", "format": "date", "description": "The date the medication expires." },
        "price": { "type": "number", "description": "Unit price of the medication." },
        "unit": { "type": "string", "description": "The unit of measurement (e.g., Tablets, Capsules)." },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Timestamp of the last update." }
      },
      "required": ["name", "stock", "reorderThreshold", "expirationDate"]
    },
    "InventoryLog": {
      "title": "Inventory Log",
      "description": "A log entry for stock changes.",
      "type": "object",
      "properties": {
        "medicationId": { "type": "string", "description": "Reference to the medication." },
        "type": { "type": "string", "enum": ["IN", "OUT", "ADJUST"], "description": "Type of stock movement." },
        "quantity": { "type": "number", "description": "Amount changed." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the change occurred." },
        "reason": { "type": "string", "description": "Optional reason for adjustment." }
      },
      "required": ["medicationId", "type", "quantity", "timestamp"]
    },
    "Token": {
      "title": "Token",
      "description": "A patient queue token.",
      "type": "object",
      "properties": {
        "patientName": { "type": "string", "description": "The name of the patient." },
        "tokenNumber": { "type": "string", "description": "The unique token identifier." },
        "status": { "type": "string", "enum": ["PENDING", "PROCESSING", "COMPLETED", "CANCELLED"], "description": "Current status of the token." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the token was issued." }
      },
      "required": ["patientName", "tokenNumber", "status", "timestamp"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A completed medication sale.",
      "type": "object",
      "properties": {
        "tokenNumber": { "type": "string", "description": "Optional reference to a patient token." },
        "patientName": { "type": "string", "description": "Name of the patient." },
        "totalAmount": { "type": "number", "description": "Total value of the sale." },
        "paymentMethod": { "type": "string", "enum": ["CASH", "CARD", "INSURANCE"], "description": "How the sale was paid." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the sale occurred." },
        "items": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "medicationId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        }
      },
      "required": ["patientName", "totalAmount", "paymentMethod", "timestamp", "items"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "A medication supplier.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "category": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["name", "contactPerson", "email", "phone", "address"]
    },
    "PurchaseOrder": {
      "title": "Purchase Order",
      "description": "A bulk order from a supplier.",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["PENDING", "ORDERED", "RECEIVED", "CANCELLED"] },
        "orderDate": { "type": "string", "format": "date" },
        "receivedDate": { "type": "string", "format": "date" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "medicationId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" }
            }
          }
        }
      },
      "required": ["supplierId", "totalAmount", "status", "orderDate", "items"]
    }
  },
  "firestore": {
    "/medications": {
      "schema": "Medication",
      "description": "Collection of all medications in the pharmacy."
    },
    "/inventory_logs": {
      "schema": "InventoryLog",
      "description": "History of all inventory movements."
    },
    "/tokens": {
      "schema": "Token",
      "description": "Queue of patient tokens."
    },
    "/sales": {
      "schema": "Sale",
      "description": "Record of all completed transactions."
    },
    "/suppliers": {
      "schema": "Supplier",
      "description": "Directory of medication suppliers."
    },
    "/purchase_orders": {
      "schema": "PurchaseOrder",
      "description": "Records of bulk procurement orders."
    }
  }
}
